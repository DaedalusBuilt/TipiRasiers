# =========================================
# Tipi Raisers Web - Environment Variables
# Copy this file to .env and fill in values
# =========================================

# Server
PORT=3000
NODE_ENV=development

# Session Secret - TODO: Replace with a strong random string
SESSION_SECRET=your-very-secret-key-change-this-in-production

# Admin Credentials - TODO: Change before deploying
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# TODO: Configure email (Nodemailer/SendGrid) for contact form
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=yourpassword
EMAIL_FROM=noreply@tipirasers.org

# TODO: Configure Stripe for donation processing
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# TODO: Configure PayPal as alternative donation method
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Site Config
SITE_URL=http://localhost:3000
SITE_NAME=Tipi Raisers

# GitHub Auto-Sync (pushes database to GitHub on every post change)
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo (full)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=TipiRaisersWeb
GITHUB_BRANCH=main
