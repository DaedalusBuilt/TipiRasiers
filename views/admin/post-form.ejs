<%- include('../partials/head') %>

<body class="admin-body">
<header class="admin-header">
  <div class="admin-header-inner">
    <a href="/" class="logo"><span>🏠</span> Tipi Raisers</a>
    <nav class="admin-nav">
      <a href="/admin">← Dashboard</a>
      <a href="/" target="_blank">View Site</a>
      <a href="/admin/logout" class="admin-logout">Log Out</a>
    </nav>
  </div>
</header>

<main class="admin-main">
  <div class="admin-container">
    <% if (typeof flash !== 'undefined' && flash.error && flash.error.length) { %>
      <div class="flash flash-error"><%= flash.error[0] %></div>
    <% } %>

    <h1 class="admin-title"><%= post ? 'Edit Post' : 'New Post' %></h1>

    <form action="<%= post ? '/admin/posts/' + post.id : '/admin/posts' %>" method="POST" enctype="multipart/form-data" class="admin-form">

      <div class="admin-form-grid">
        <!-- ── Main Content ── -->
        <div class="admin-form-main">
          <div class="form-group">
            <label for="title">Post Title <span class="required">*</span></label>
            <input type="text" id="title" name="title" required
                   value="<%= post ? post.title : '' %>" placeholder="Enter a compelling title..." />
          </div>

          <div class="form-group">
            <label for="content">Content (Markdown supported) <span class="required">*</span></label>
            <textarea id="content" name="content" rows="20" required
                      placeholder="Write your post content here. Markdown is supported."><%= post ? post.content : '' %></textarea>
            <small>Tip: Use **bold**, # headings, - lists, and [links](url) for formatting.</small>
          </div>

          <div class="form-group">
            <label for="excerpt">Excerpt (shown on blog listing)</label>
            <textarea id="excerpt" name="excerpt" rows="3"
                      placeholder="Short summary shown on the blog listing page..."><%= post ? post.excerpt : '' %></textarea>
          </div>
        </div>

        <!-- ── Sidebar ── -->
        <div class="admin-form-sidebar">

          <!-- Publish -->
          <div class="sidebar-card">
            <h3>Publish</h3>
            <div class="form-group">
              <label for="status">Status</label>
              <select id="status" name="status">
                <option value="draft"     <%= !post || post.status === 'draft'      ? 'selected' : '' %>>Draft</option>
                <option value="published" <%= post  && post.status === 'published'  ? 'selected' : '' %>>Published</option>
              </select>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary btn-block"><%= post ? 'Update Post' : 'Create Post' %></button>
              <a href="/admin" class="btn btn-ghost btn-block">Cancel</a>
            </div>
          </div>

          <!-- Details -->
          <div class="sidebar-card">
            <h3>Details</h3>
            <div class="form-group">
              <label for="category">Category</label>
              <select id="category" name="category">
                <option value="">Select category...</option>
                <% ['Progress Update','Community Stories','How to Help','News & Events','Construction Updates','Volunteer Spotlight','Housing Needs Assessment and Policy Research'].forEach(cat => { %>
                  <option value="<%= cat %>" <%= post && post.category === cat ? 'selected' : '' %>><%= cat %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <!-- Photos -->
          <div class="sidebar-card">
            <h3>Photos</h3>
            <% if (storageMode === 'local') { %>
              <p style="color:#c0392b;font-size:0.85rem;font-weight:600;margin-bottom:8px;">
                ⚠️ Supabase not connected — photos will be lost on next server restart!
              </p>
            <% } %>
            <p class="form-hint">First photo becomes the featured image. Drag to reorder.</p>

            <!-- Existing images grid -->
            <% if (post && post.images && post.images.length > 0) { %>
              <div class="img-grid" id="existingImgGrid">
                <% post.images.forEach((img, i) => { %>
                  <div class="img-grid-item" data-url="<%= img %>">
                    <img src="<%= img %>" alt="Photo <%= i+1 %>" />
                    <button type="button" class="img-remove-btn" onclick="removeImage(this)" title="Remove">✕</button>
                    <% if (i === 0) { %><span class="img-featured-badge">Featured</span><% } %>
                    <input type="hidden" name="existingImages" value="<%= img %>" class="existing-img-input" />
                  </div>
                <% }) %>
              </div>
            <% } %>

            <!-- Upload new photos -->
            <div class="file-upload-box" id="fileUploadBox">
              <input type="file" id="imageFiles" name="imageFiles" accept="image/*" multiple class="file-input" />
              <label for="imageFiles" class="file-upload-label">
                <span class="file-icon">📷</span>
                <span id="fileUploadText">Click to upload photos</span>
                <small>JPG, PNG, GIF, WebP — max 10MB each — multiple OK</small>
              </label>
            </div>

            <!-- New image previews -->
            <div class="img-grid" id="newImgPreview" style="margin-top:10px"></div>
          </div>

          <!-- Danger Zone -->
          <% if (post) { %>
            <div class="sidebar-card sidebar-danger">
              <h3>Danger Zone</h3>
              <form action="/admin/posts/<%= post.id %>/delete" method="POST"
                    onsubmit="return confirm('Delete this post? This cannot be undone.')">
                <button type="submit" class="btn btn-danger btn-block">Delete This Post</button>
              </form>
            </div>
          <% } %>

        </div>
      </div>
    </form>
  </div>
</main>

<script>
// Update label when files are chosen and show previews
document.getElementById('imageFiles').addEventListener('change', function () {
  const files = Array.from(this.files);
  document.getElementById('fileUploadText').textContent =
    files.length === 1 ? files[0].name : files.length + ' photos selected';

  const preview = document.getElementById('newImgPreview');
  preview.innerHTML = '';
  files.forEach(file => {
    const reader = new FileReader();
    reader.onload = e => {
      const div = document.createElement('div');
      div.className = 'img-grid-item';
      div.innerHTML = `<img src="${e.target.result}" alt="${file.name}" />`;
      preview.appendChild(div);
    };
    reader.readAsDataURL(file);
  });
});

// Remove existing image
function removeImage(btn) {
  const item = btn.closest('.img-grid-item');
  item.remove();
  // Re-badge first remaining as Featured
  const grid = document.getElementById('existingImgGrid');
  if (grid) {
    grid.querySelectorAll('.img-featured-badge').forEach(b => b.remove());
    const first = grid.querySelector('.img-grid-item');
    if (first) {
      const badge = document.createElement('span');
      badge.className = 'img-featured-badge';
      badge.textContent = 'Featured';
      first.appendChild(badge);
    }
  }
}
</script>

<script src="/js/main.js"></script>
</body>
</html>
